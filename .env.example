# ── Site ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://bethlem.co

# ── Supabase (self-hosted) ────────────────────────────────────────────────────
# The browser calls Supabase through nginx at /supabase/ (see infra/nginx/nginx.conf)
NEXT_PUBLIC_SUPABASE_URL=https://bethlem.co/supabase
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-jwt-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-jwt-here

# ── Discourse ─────────────────────────────────────────────────────────────────
DISCOURSE_BASE_URL=https://forum.bethlem.co
# Must match DISCOURSE_SSO_SECRET in infra/docker-compose.yml exactly
DISCOURSE_SSO_SECRET=a-random-secret-minimum-32-characters-long
DISCOURSE_DB_PASSWORD=secure-discourse-db-password
DISCOURSE_ADMIN_USERNAME=admin
DISCOURSE_ADMIN_PASSWORD=secure-admin-password
DISCOURSE_ADMIN_EMAIL=admin@bethlem.co

# ── SMTP (for both Next.js auth emails and Discourse notifications) ───────────
SMTP_HOST=smtp.postmarkapp.com
SMTP_PORT=587
SMTP_USER=your-api-token
SMTP_PASSWORD=your-api-token
