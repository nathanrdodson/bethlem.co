---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Blog"
  description="Stories, updates, and honest accounts of living with Bethlem myopathy."
>
  <div class="px-5 md:px-8 py-12 md:py-20 max-w-5xl mx-auto">
    <header class="mb-12">
      <h1 class="font-serif text-3xl md:text-5xl font-bold text-navy leading-tight mb-4">
        The blog
      </h1>
      <p class="text-base md:text-lg text-gray font-sans max-w-xl leading-relaxed">
        Written like letters — honest, personal, and meant to be read slowly.
      </p>
    </header>

    {allPosts.length === 0 ? (
      <p class="text-gray font-sans">No posts yet — check back soon.</p>
    ) : (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {allPosts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            slug={post.slug}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
          />
        ))}
      </div>
    )}
  </div>
</BaseLayout>
