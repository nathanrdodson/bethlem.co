---
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const featured = allPosts.find((p) => p.data.featured) ?? allPosts[0];
const recent = allPosts.filter((p) => p.slug !== featured?.slug).slice(0, 4);
---

<BaseLayout title="Home">
  <!-- Hero -->
  <section class="px-5 md:px-8 pt-16 pb-12 md:pt-24 md:pb-20 max-w-5xl mx-auto">
    <div class="max-w-2xl">
      <div class="flex items-center gap-3 mb-6">
        <svg viewBox="0 0 52 56" width="28" height="32" aria-hidden="true">
          <line x1="0" y1="9" x2="32" y2="9" stroke="#D85A30" stroke-width="4" stroke-linecap="round"/>
          <line x1="4" y1="20" x2="44" y2="20" stroke="#D85A30" stroke-width="4" stroke-linecap="round"/>
          <line x1="2" y1="31" x2="36" y2="31" stroke="#D85A30" stroke-width="4" stroke-linecap="round"/>
          <line x1="0" y1="42" x2="24" y2="42" stroke="#D85A30" stroke-width="4" stroke-linecap="round"/>
        </svg>
        <span class="text-sm font-semibold text-gray font-sans uppercase tracking-widest">bethlem.co</span>
      </div>

      <h1 class="font-serif text-4xl md:text-6xl font-bold text-navy leading-tight md:leading-[1.1] mb-6">
        Living with<br class="hidden md:block" /> Bethlem myopathy.
      </h1>

      <p class="text-lg md:text-xl text-charcoal font-sans leading-relaxed mb-8 max-w-xl">
        A personal site about navigating a rare muscle condition — written as letters, not lectures.
        Stories, resources, and honest accounts from the inside.
      </p>

      <div class="flex flex-wrap gap-4">
        <a
          href="/blog"
          class="inline-flex items-center min-h-[44px] px-6 bg-coral text-white font-semibold font-sans text-sm rounded-md hover:bg-[#c04f28] transition-colors"
        >
          Read the blog
        </a>
        <a
          href="/about"
          class="inline-flex items-center min-h-[44px] px-6 border-[1.5px] border-navy text-navy font-semibold font-sans text-sm rounded-md hover:bg-navy hover:text-white transition-colors"
        >
          About this site
        </a>
      </div>
    </div>
  </section>

  <!-- Featured post -->
  {featured && (
    <section class="px-5 md:px-8 py-12 md:py-16 border-t border-border-light">
      <div class="max-w-5xl mx-auto">
        <p class="text-xs font-semibold text-gray font-sans uppercase tracking-widest mb-6">Latest</p>
        <div class="grid md:grid-cols-5 gap-8 md:gap-12 items-start">
          <div class="md:col-span-3">
            {featured.data.tags.length > 0 && (
              <div class="flex flex-wrap gap-2 mb-4">
                {featured.data.tags.map((tag: string) => (
                  <span class="inline-block text-xs font-semibold font-sans px-3.5 py-1 rounded-full bg-[#E6F1FB] text-[#185FA5]">{tag}</span>
                ))}
              </div>
            )}
            <h2 class="font-serif text-2xl md:text-4xl font-bold text-navy leading-tight mb-4">
              <a href={`/blog/${featured.slug}`} class="hover:text-coral transition-colors">
                {featured.data.title}
              </a>
            </h2>
            <p class="text-base text-charcoal font-sans leading-relaxed mb-6">{featured.data.description}</p>
            <a href={`/blog/${featured.slug}`} class="text-coral font-semibold font-sans text-sm hover:underline min-h-[44px] inline-flex items-center">
              Read more →
            </a>
          </div>
          <div class="md:col-span-2 hidden md:block">
            <div class="bg-white border border-border/50 rounded-xl p-8 flex flex-col gap-6">
              <p class="font-serif text-navy text-lg font-bold leading-snug italic">
                "There is a particular kind of relief that comes with a diagnosis. Not the relief of good news. It's the relief of a name."
              </p>
              <span class="text-xs text-gray font-sans">— from the first post</span>
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Recent posts -->
  {recent.length > 0 && (
    <section class="px-5 md:px-8 py-12 md:py-16 border-t border-border-light">
      <div class="max-w-5xl mx-auto">
        <div class="flex items-center justify-between mb-8">
          <p class="text-xs font-semibold text-gray font-sans uppercase tracking-widest">More posts</p>
          <a href="/blog" class="text-coral font-semibold font-sans text-sm hover:underline min-h-[44px] flex items-center">
            View all →
          </a>
        </div>
        <div class="grid sm:grid-cols-2 gap-5">
          {recent.map((post) => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              slug={post.slug}
              pubDate={post.data.pubDate}
              tags={post.data.tags}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- About strip -->
  <section class="px-5 md:px-8 py-14 md:py-20 border-t border-border-light bg-navy">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="font-serif text-2xl md:text-3xl font-bold text-white mb-4">What is Bethlem myopathy?</h2>
      <p class="text-base text-white/75 font-sans leading-relaxed mb-8">
        A rare congenital muscle disorder affecting roughly 1 in 200,000 people, caused by mutations
        in the COL6 family of genes. This site exists to make the experience of living with it
        a little less lonely.
      </p>
      <a
        href="/about"
        class="inline-flex items-center min-h-[44px] px-6 bg-coral text-white font-semibold font-sans text-sm rounded-md hover:bg-[#c04f28] transition-colors"
      >
        Learn more
      </a>
    </div>
  </section>
</BaseLayout>
