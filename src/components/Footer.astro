---
const year = new Date().getFullYear();
---

<footer class="border-t border-border-light mt-20">
  <div class="max-w-5xl mx-auto px-5 md:px-8 py-10 flex flex-col md:flex-row items-center justify-between gap-4">
    <div class="flex items-center gap-2.5">
      <svg viewBox="0 0 52 56" width="16" height="18" aria-hidden="true">
        <line x1="0" y1="9" x2="32" y2="9" stroke="#D85A30" stroke-width="4.5" stroke-linecap="round"/>
        <line x1="4" y1="20" x2="44" y2="20" stroke="#D85A30" stroke-width="4.5" stroke-linecap="round"/>
        <line x1="2" y1="31" x2="36" y2="31" stroke="#D85A30" stroke-width="4.5" stroke-linecap="round"/>
        <line x1="0" y1="42" x2="24" y2="42" stroke="#D85A30" stroke-width="4.5" stroke-linecap="round"/>
      </svg>
      <span class="font-serif font-bold text-navy text-sm">Bethlem</span>
    </div>

    <p class="text-xs text-gray font-sans text-center">
      Personal experiences only — not medical advice.
    </p>

    <p class="text-xs text-gray font-sans">
      &copy; {year} Nathan Dodson
    </p>
  </div>
</footer>
