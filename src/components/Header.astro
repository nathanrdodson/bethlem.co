---
const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Writing', href: '/writing' },
  { label: 'About', href: '/about' },
];

const pathname = Astro.url.pathname;
---

<header class="border-b border-border-light bg-cream/95 backdrop-blur-sm sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-6 md:px-10 flex items-center justify-between h-16">

    <a href="/" class="flex items-center min-h-[44px]" aria-label="Bethlem — home">
      <img src="/brand/bethlem-logo-light.svg" alt="Bethlem" class="h-8 w-auto" />
    </a>

    <nav class="hidden md:flex items-center gap-1" aria-label="Main navigation">
      {navLinks.map(({ label, href }) => (
        <a
          href={href}
          class={`px-4 py-2 rounded text-sm font-semibold font-sans transition-colors ${
            (href === '/' ? pathname === '/' : pathname.startsWith(href))
              ? 'text-navy bg-coral/10'
              : 'text-charcoal hover:text-navy hover:bg-border-light'
          }`}
        >
          {label}
        </a>
      ))}
    </nav>

    <label class="md:hidden cursor-pointer p-2 min-h-[44px] min-w-[44px] flex items-center justify-center" for="nav-toggle" aria-label="Toggle navigation">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="#042C53" stroke-width="2" stroke-linecap="round">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </label>
  </div>

  <input type="checkbox" id="nav-toggle" class="sr-only peer" aria-hidden="true" />
  <nav class="peer-checked:flex hidden md:hidden flex-col border-t border-border-light bg-cream px-6 py-3" aria-label="Mobile navigation">
    {navLinks.map(({ label, href }) => (
      <a
        href={href}
        class={`px-2 py-3 text-base font-semibold font-sans border-b border-border-light last:border-0 min-h-[44px] flex items-center ${
          (href === '/' ? pathname === '/' : pathname.startsWith(href)) ? 'text-coral' : 'text-charcoal hover:text-coral'
        }`}
      >
        {label}
      </a>
    ))}
  </nav>
</header>
