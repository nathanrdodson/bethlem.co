---
const navLinks = [
  { label: 'Blog', href: '/blog' },
  { label: 'About', href: '/about' },
];

const pathname = Astro.url.pathname;
---

<header class="border-b border-border-light bg-cream/90 backdrop-blur-sm sticky top-0 z-50">
  <div class="max-w-5xl mx-auto px-5 md:px-8 flex items-center justify-between h-16">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 min-h-[44px]" aria-label="Bethlem — home">
      <svg viewBox="0 0 52 56" width="22" height="25" aria-hidden="true">
        <line x1="0" y1="9" x2="32" y2="9" stroke="#D85A30" stroke-width="4.5" stroke-linecap="round"/>
        <line x1="4" y1="20" x2="44" y2="20" stroke="#D85A30" stroke-width="4.5" stroke-linecap="round"/>
        <line x1="2" y1="31" x2="36" y2="31" stroke="#D85A30" stroke-width="4.5" stroke-linecap="round"/>
        <line x1="0" y1="42" x2="24" y2="42" stroke="#D85A30" stroke-width="4.5" stroke-linecap="round"/>
      </svg>
      <span class="font-serif font-bold text-xl text-navy tracking-tight">Bethlem</span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-1" aria-label="Main navigation">
      {navLinks.map(({ label, href }) => (
        <a
          href={href}
          class={`px-4 py-2 rounded-md text-sm font-semibold font-sans transition-colors min-h-[44px] flex items-center ${
            pathname.startsWith(href)
              ? 'text-navy bg-border-light'
              : 'text-charcoal hover:text-navy hover:bg-border-light'
          }`}
        >
          {label}
        </a>
      ))}
    </nav>

    <!-- Mobile nav toggle -->
    <label class="md:hidden cursor-pointer p-2 min-h-[44px] min-w-[44px] flex items-center justify-center" for="nav-toggle" aria-label="Toggle navigation">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="#042C53" stroke-width="2" stroke-linecap="round">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </label>
  </div>

  <!-- Mobile nav drawer (CSS-only) -->
  <input type="checkbox" id="nav-toggle" class="sr-only peer" aria-hidden="true" />
  <nav
    class="peer-checked:flex hidden md:hidden flex-col border-t border-border-light bg-cream px-5 py-3"
    aria-label="Mobile navigation"
  >
    {navLinks.map(({ label, href }) => (
      <a
        href={href}
        class={`px-2 py-3 text-base font-semibold font-sans border-b border-border-light last:border-0 min-h-[44px] flex items-center ${
          pathname.startsWith(href) ? 'text-coral' : 'text-charcoal hover:text-coral'
        }`}
      >
        {label}
      </a>
    ))}
  </nav>
</header>
